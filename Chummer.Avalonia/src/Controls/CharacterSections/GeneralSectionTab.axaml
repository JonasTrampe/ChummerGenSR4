<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Chummer.NewUI.Controls"
             xmlns:vm="clr-namespace:Chummer.NewUI.ViewModels"
             x:Class="Chummer.NewUI.Controls.CharacterSections.GeneralSectionTab"
             x:DataType="vm:GeneralSectionViewModel">
    <controls:TreeDetailPane TreeWidth="280" ContentMargin="2 8 2 4">
        <controls:TreeDetailPane.HeaderContent>
            <StackPanel Margin="2 0 2 0" Orientation="Horizontal" Spacing="2">
                <Button Content="Gabe hinzufügen" Click="OnAddQualityClick" />
                <Button Content="Gabe austauschen" />
                <Button Content="Löschen" Click="OnDeleteQualityClick" />
            </StackPanel>
        </controls:TreeDetailPane.HeaderContent>
        <controls:TreeDetailPane.TreeContent>
            <TreeView ItemsSource="{Binding Qualities}" SelectedItem="{Binding SelectedQualityNode, Mode=TwoWay}">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" />
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </controls:TreeDetailPane.TreeContent>
        <controls:TreeDetailPane.DetailContent>
            <ScrollViewer Margin="2 8 2 4">
            <StackPanel Margin="4,0,4,0" Spacing="10">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,60,Auto,60">
                    <TextBlock Grid.Column="0" Text="Spitzname:" VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBox Grid.Column="1" Text="{Binding Alias}" Width="260" HorizontalAlignment="Left" />
                    <TextBlock Grid.Column="2" Text="Metatyp:" VerticalAlignment="Center"
                               Margin="20,0,6,0" />
                    <TextBlock Grid.Column="3" Text="{Binding Metatype}" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="Nuyen:" VerticalAlignment="Center"
                               Margin="20,0,6,0" />
                    <TextBox Grid.Column="5" Text="{Binding Nuyen}" />
                    <TextBlock Grid.Column="6" Text="{Binding NuyenEquivalent}" VerticalAlignment="Center"
                               Margin="6,0,0,0" />
                </Grid>

                <StackPanel>
                    <Grid ColumnDefinitions="150,40,26,60,90,60" Margin="0,0,0,2">
                        <TextBlock Grid.Column="0" Classes="gridHeader" Text="Attribute" />
                        <TextBlock Grid.Column="1" Classes="gridHeader" Text="Basis" />
                        <TextBlock Grid.Column="3" Classes="gridHeader" Text="(Verst.)" />
                        <TextBlock Grid.Column="4" Classes="gridHeader" Text="Metatyp Begrenzu." />
                        <TextBlock Grid.Column="5" Classes="gridHeader" Text="Quelle" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Attributes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AttributeRowViewModel">
                                <controls:AttributeRow Code="{Binding Code}" AttributeName="{Binding AttributeName}"
                                                        Base="{Binding Base}" Augmented="{Binding Augmented}"
                                                        Range="{Binding Range}" Source="{Binding Source}"
                                                        ShowRemove="{Binding ShowRemove}"
                                                        IsEnabled="{Binding IsAttributeEnabled}"
                                                        IsCreateMode="{Binding IsCreateMode}"
                                                        BaseValue="{Binding BaseValue, Mode=TwoWay}"
                                                        MinValue="{Binding MinValue}" MaxValue="{Binding MaxValue}"
                                                        RaiseClicked="OnRaiseAttributeClick" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Classes="groupBox" Padding="10" HorizontalAlignment="Left"
                            Margin="0,4,0,0"
                            IsVisible="{Binding ShowMysticAdeptMagSplit}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Magieadept MAG-Aufteilung" FontWeight="Bold" />
                            <Grid ColumnDefinitions="90,90">
                                <TextBlock Grid.Column="0" Text="Magier" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Adept" FontWeight="SemiBold" />
                            </Grid>
                            <Grid ColumnDefinitions="90,90">
                                <TextBox Grid.Column="0" Text="{Binding MysticAdeptMagicianMagSplit}" Width="60"
                                         HorizontalAlignment="Left" IsReadOnly="True" />
                                <TextBlock Grid.Column="1" Text="{Binding MysticAdeptAdeptMagSplit}" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Connections:" FontWeight="Bold" Margin="0,0,0,4" />
                    <Button Content="Connection hinzufügen" HorizontalAlignment="Left"
                            Margin="0,0,0,6" Click="OnAddContactClick" />
                    <ItemsControl ItemsSource="{Binding Contacts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ContactRowViewModel">
                                <Border BorderBrush="#E4E4E4" BorderThickness="0,0,0,1" Padding="0,0,0,4"
                                        Margin="0,0,0,4">
                                    <Grid ColumnDefinitions="160,Auto,56,Auto,56,Auto" ColumnSpacing="6">
                                        <TextBox Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Connection:" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="2" Text="{Binding Connection}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="Loyalität:" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="4" Text="{Binding Loyalty}" VerticalAlignment="Center" />
                                        <Button Grid.Column="5" Content="Löschen" Click="OnDeleteContactClick"
                                                Tag="{Binding ContactId}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Feinde" FontWeight="Bold" Margin="0,0,0,4" />
                    <Button Content="Feind hinzufügen" HorizontalAlignment="Left"
                            Margin="0,0,0,6" Click="OnAddEnemyClick" />
                    <ItemsControl ItemsSource="{Binding Enemies}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ContactRowViewModel">
                                <Border BorderBrush="#E4E4E4" BorderThickness="0,0,0,1" Padding="0,0,0,4"
                                        Margin="0,0,0,4">
                                    <Grid ColumnDefinitions="160,Auto,56,Auto,56,Auto" ColumnSpacing="6">
                                        <TextBox Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Connection:" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="2" Text="{Binding Connection}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="Loyalität:" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="4" Text="{Binding Loyalty}" VerticalAlignment="Center" />
                                        <Button Grid.Column="5" Content="Löschen" Click="OnDeleteContactClick"
                                                Tag="{Binding ContactId}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
            </ScrollViewer>
        </controls:TreeDetailPane.DetailContent>
    </controls:TreeDetailPane>
</UserControl>
