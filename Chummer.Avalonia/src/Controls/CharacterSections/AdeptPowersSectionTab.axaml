<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.NewUI.Controls.CharacterSections.AdeptPowersSectionTab">
    <DockPanel Margin="2 8 2 4">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
            <Button Content="Kraft" />
            <TextBlock Text="Kraftpunkte: 6 (0,00 verbleibend)" FontWeight="Bold"
                       VerticalAlignment="Center" />

        </StackPanel>
        <ScrollViewer>
            <StackPanel Name="AdeptPowersPanel" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
