<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Chummer.NewUI.ViewModels"
             x:Class="Chummer.NewUI.Controls.CharacterSections.CalendarTab"
             x:DataType="vm:CalendarSectionViewModel">
    <DockPanel Margin="4">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="2" Margin="0,0,0,4">
            <Button Content="Wochen hinzufügen" />
            <Button Content="Woche bearbeiten" />
            <Button Content="Startdatum ändern" HorizontalAlignment="Right" />
        </StackPanel>
        <Grid ColumnDefinitions="120,*" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Classes="gridHeader" Text="Datum" />
            <TextBlock Grid.Column="1" Classes="gridHeader" Text="Notizen" />
        </Grid>
        <ListBox ItemsSource="{Binding Weeks}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:CalendarWeekRowViewModel">
                <Grid ColumnDefinitions="120,*">
                    <TextBlock Grid.Column="0" Text="{Binding Date}" />
                    <TextBlock Grid.Column="1" Text="{Binding Notes}" TextWrapping="Wrap" />
                </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
