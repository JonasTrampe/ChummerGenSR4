<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Chummer.NewUI.Controls"
             xmlns:vm="clr-namespace:Chummer.NewUI.ViewModels"
             x:Class="Chummer.NewUI.Controls.CharacterSections.CyberwareSectionTab"
             x:DataType="vm:CyberwareSectionViewModel">
    <controls:TreeDetailPane TreeWidth="330" ContentMargin="4">
        <controls:TreeDetailPane.HeaderContent>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Spacing="2">
                <Button Content="Cyberware hinzufügen" Click="OnAddCyberwareClick" />
                <Button Content="Bioware hinzufügen" Click="OnAddBiowareClick" />
                <Button Content="Löschen" Click="OnDeleteClick" />
            </StackPanel>
        </controls:TreeDetailPane.HeaderContent>
        <controls:TreeDetailPane.TreeContent>
            <TreeView ItemsSource="{Binding Roots}" SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" />
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </controls:TreeDetailPane.TreeContent>
        <controls:TreeDetailPane.DetailContent>
            <StackPanel Margin="8,0,0,0" Spacing="6">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Width="80" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedNode.Name, TargetNullValue=–}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Kategorie:" Width="80" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedNode.Category, TargetNullValue=–}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Rating:" Width="80" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedNode.Rating, TargetNullValue=–}" />
            </Grid>
            <Separator Margin="0,4" />
            <TextBlock Text="Verbrauchte Essenz" FontWeight="Bold" />
            <Grid ColumnDefinitions="Auto,60" RowDefinitions="Auto,Auto" RowSpacing="2">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Cyberware:" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CyberwareEssence}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Bioware:" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BiowareEssence}" />
            </Grid>
            </StackPanel>
        </controls:TreeDetailPane.DetailContent>
    </controls:TreeDetailPane>
</UserControl>
