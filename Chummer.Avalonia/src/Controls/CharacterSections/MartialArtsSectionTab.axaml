<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Chummer.NewUI.Controls"
             xmlns:vm="clr-namespace:Chummer.NewUI.ViewModels"
             x:Class="Chummer.NewUI.Controls.CharacterSections.MartialArtsSectionTab"
             x:DataType="vm:MartialArtsSectionViewModel">
    <UserControl.Styles>
        <Style Selector="TextBlock.header">
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="Foreground" Value="#888888" />
        </Style>
    </UserControl.Styles>
    <controls:TreeDetailPane TreeWidth="220" ContentMargin="2 8 2 4">
        <controls:TreeDetailPane.HeaderContent>
            <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,0,4">
                <Button Content="Kampfkunst hinzufügen" />
                <Button Content="Manöver hinzufügen" />
                <Button Content="Löschen" />
            </StackPanel>
        </controls:TreeDetailPane.HeaderContent>
        <controls:TreeDetailPane.TreeContent>
            <ListBox ItemsSource="{Binding Items}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:MartialArtsListItemViewModel">
                        <TextBlock Text="{Binding Text}" Classes.header="{Binding IsHeader}"
                                   Margin="{Binding IndentLeft, StringFormat='{}{0},0,0,0'}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </controls:TreeDetailPane.TreeContent>
        <controls:TreeDetailPane.DetailContent>
            <StackPanel Margin="12,0,0,0" Spacing="6">
                <Grid ColumnDefinitions="Auto,Auto">
                    <TextBlock Text="Stufe:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Button Grid.Column="1" Classes="iconButton">
                        <Image Source="avares://Chummer.Avalonia/assets/icons/add.png" />
                    </Button>
                </Grid>
                <TextBlock Text="Quelle:" />
            </StackPanel>
        </controls:TreeDetailPane.DetailContent>
    </controls:TreeDetailPane>
</UserControl>
