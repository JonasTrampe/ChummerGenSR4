<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Chummer.NewUI.ViewModels"
             x:Class="Chummer.NewUI.Controls.CharacterSections.CharacterInfoSectionTab"
             x:DataType="vm:CharacterInfoSectionViewModel">
    <ScrollViewer Margin="8">
        <StackPanel Spacing="10">
            <Grid ColumnDefinitions="Auto,120,Auto,120,Auto,120,Auto,*" RowDefinitions="Auto,Auto"
                  RowSpacing="6" ColumnSpacing="6">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Geschlecht:"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Gender}" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Augenfarbe:"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding EyeColor}" />
                <TextBlock Grid.Row="0" Grid.Column="4" Text="Haarfarbe:"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding HairColor}" />
                <TextBlock Grid.Row="0" Grid.Column="6" Text="Spielername:"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="7" Text="{Binding PlayerName}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Grösse:" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Height}" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Gewicht:" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Weight}" />
                <TextBlock Grid.Row="1" Grid.Column="4" Text="Hautfarbe:"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding SkinColor}" />
            </Grid>

            <Grid ColumnDefinitions="Auto,50,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="4" ColumnSpacing="6">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Straßenruf:"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding StreetCred}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Schlechter Ruf:"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Notoriety}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Prominenz:"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PublicAwareness}" />
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Portrait: (210px x 310px)" VerticalAlignment="Center" />
                <Button Content="Ändern" />
                <Button Content="Löschen" />
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Beschreibung:" FontWeight="Bold" />
                <Border Classes="groupBox" Height="70">
                    <TextBox Text="{Binding Description}" AcceptsReturn="True" TextWrapping="Wrap"
                             BorderThickness="0" />
                </Border>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Hintergrund:" FontWeight="Bold" />
                <Border Classes="groupBox" Height="70">
                    <TextBox Text="{Binding Background}" AcceptsReturn="True" TextWrapping="Wrap"
                             BorderThickness="0" />
                </Border>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Konzept:" FontWeight="Bold" />
                <Border Classes="groupBox" Height="70">
                    <TextBox Text="{Binding Concept}" AcceptsReturn="True" TextWrapping="Wrap"
                             BorderThickness="0" />
                </Border>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Notizen:" FontWeight="Bold" />
                <Border Classes="groupBox" Height="70">
                    <TextBox Text="{Binding Notes}" AcceptsReturn="True" TextWrapping="Wrap"
                             BorderThickness="0" />
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
