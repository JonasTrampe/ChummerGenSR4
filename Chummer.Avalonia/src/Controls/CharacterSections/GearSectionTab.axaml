<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Chummer.NewUI.Controls"
             xmlns:vm="clr-namespace:Chummer.NewUI.ViewModels"
             x:Class="Chummer.NewUI.Controls.CharacterSections.GearSectionTab"
             x:DataType="vm:GearSectionViewModel">
    <TabControl Margin="4">
        <TabItem Header="Lebensstil">
            <Grid ColumnDefinitions="200,4,*" Margin="4">
                <DockPanel Grid.Column="0">
                    <Button DockPanel.Dock="Top" Content="Lebensstil hinzufügen" Margin="0,0,0,4" />
                    <ListBox ItemsSource="{Binding Lifestyles}" />
                </DockPanel>
                <GridSplitter Grid.Column="1" Background="#E4E4E4" />
                <StackPanel Grid.Column="2" Margin="8,0,0,0" Spacing="4">
                    <TextBlock Text="{Binding LifestyleCost}" />
                    <TextBlock
                        Text="Komfort / Unterhaltung / Grundversorgung / Wohngegend / Sicherheit"
                        Foreground="#666666" FontStyle="Italic" />
                </StackPanel>
            </Grid>
        </TabItem>
        <TabItem Header="Panzerung">
            <controls:TreeDetailPane TreeWidth="220" ContentMargin="4">
                <controls:TreeDetailPane.HeaderContent>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Spacing="2">
                        <Button Content="Panzerung hinzufügen" />
                        <Button Content="Löschen" />
                        <Button Content="Panzerungsset hinzufügen" />
                    </StackPanel>
                </controls:TreeDetailPane.HeaderContent>
                <controls:TreeDetailPane.TreeContent>
                    <TreeView ItemsSource="{Binding Armor}" SelectedItem="{Binding SelectedArmor, Mode=TwoWay}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Name}" />
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </controls:TreeDetailPane.TreeContent>
                <controls:TreeDetailPane.DetailContent>
                    <StackPanel Margin="8,0,0,0" Spacing="6">
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                        <TextBlock Grid.Row="0" Text="Name:" Width="90" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedArmor.Name, TargetNullValue=–}" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Text="Kategorie:" Width="90" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedArmor.Category, TargetNullValue=–}" />
                        <TextBlock Grid.Row="2" Text="Stufe:" Width="90" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedArmor.Rating, TargetNullValue=–}" />
                        <TextBlock Grid.Row="3" Text="Angelegt:" Width="90" />
                        <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding SelectedArmor.Equipped}" IsEnabled="False" />
                    </Grid>
                    </StackPanel>
                </controls:TreeDetailPane.DetailContent>
            </controls:TreeDetailPane>
        </TabItem>

        <TabItem Header="Waffen">
            <controls:TreeDetailPane TreeWidth="300" ContentMargin="4">
                <controls:TreeDetailPane.HeaderContent>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Spacing="2">
                        <Button Content="Waffe hinzufügen" />
                        <Button Content="Löschen" />
                        <Button Content="Ort hinzufügen" />
                    </StackPanel>
                </controls:TreeDetailPane.HeaderContent>
                <controls:TreeDetailPane.TreeContent>
                    <TreeView ItemsSource="{Binding Weapons}" SelectedItem="{Binding SelectedWeapon, Mode=TwoWay}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Name}" />
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </controls:TreeDetailPane.TreeContent>
                <controls:TreeDetailPane.DetailContent>
                    <ScrollViewer>
                        <StackPanel Margin="8,0,0,0" Spacing="6">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                            <TextBlock Grid.Row="0" Text="Name:" Width="90" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedWeapon.Name, TargetNullValue=–}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1" Text="Kategorie:" Width="90" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedWeapon.Category, TargetNullValue=–}" />
                            <TextBlock Grid.Row="2" Text="Stufe:" Width="90" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedWeapon.Rating, TargetNullValue=–}" />
                            <TextBlock Grid.Row="3" Text="Installiert:" Width="90" />
                            <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding SelectedWeapon.Equipped}" IsEnabled="False" />
                        </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </controls:TreeDetailPane.DetailContent>
            </controls:TreeDetailPane>
        </TabItem>

        <TabItem Header="Ausrüstung">
            <controls:TreeDetailPane TreeWidth="300" ContentMargin="4">
                <controls:TreeDetailPane.HeaderContent>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Spacing="2">
                        <Button Content="Ausrüstung hinzufügen" Click="OnAddGearClick" />
                        <Button Content="Löschen" Click="OnDeleteGearClick" />
                        <Button Content="Ort hinzufügen" />
                        <CheckBox Content="Zeige nur Kommlinks" Margin="6,0,0,0" />
                    </StackPanel>
                </controls:TreeDetailPane.HeaderContent>
                <controls:TreeDetailPane.TreeContent>
                    <!-- Drag-and-drop reordering wired up in code-behind (SetUpGearDragDrop) -
                         matches the real app's gear/cyberware reordering in frmCareer/frmCreate,
                         one of the risk areas flagged in the Linux port plan's Avalonia audit. -->
                    <TreeView Name="AusruestungTree" ItemsSource="{Binding Gear}" SelectedItem="{Binding SelectedGear, Mode=TwoWay}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Name}" />
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </controls:TreeDetailPane.TreeContent>
                <controls:TreeDetailPane.DetailContent>
                    <StackPanel Margin="8,0,0,0" Spacing="6">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Text="Name:" Width="90" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedGear.Name, TargetNullValue=–}" FontWeight="SemiBold" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Text="Kategorie:" Width="90" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedGear.Category, TargetNullValue=–}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0" Text="Stufe:" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedGear.Rating, TargetNullValue=–}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Text="Installiert:" Width="90" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding SelectedGear.Equipped}" IsEnabled="False" />
                        </Grid>
                    </StackPanel>
                </controls:TreeDetailPane.DetailContent>
            </controls:TreeDetailPane>
        </TabItem>

        <TabItem Header="Haustiere und Begleiter">
            <StackPanel Margin="8" Spacing="6">
                <Button Content="Haustier hinzufügen" HorizontalAlignment="Left" />
                <Grid ColumnDefinitions="Auto,140,Auto,140,20,20,Auto" ColumnSpacing="6">
                    <TextBlock Grid.Column="0" Text="Name:" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="asd" />
                    <TextBlock Grid.Column="2" Text="Metatyp:" VerticalAlignment="Center" />
                    <Border Grid.Column="4" Classes="iconButton">
                        <Image Source="avares://Chummer.Avalonia/assets/icons/link.png" />
                    </Border>
                    <Border Grid.Column="5" Classes="iconButton">
                        <Image Source="avares://Chummer.Avalonia/assets/icons/add.png" />
                    </Border>
                    <Button Grid.Column="6" Content="Löschen" />
                </Grid>
            </StackPanel>
        </TabItem>
    </TabControl>
</UserControl>
