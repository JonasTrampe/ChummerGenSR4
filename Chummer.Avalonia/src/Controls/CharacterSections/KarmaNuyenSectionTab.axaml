<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonia="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
             x:Class="Chummer.NewUI.Controls.CharacterSections.KarmaNuyenSectionTab">
    <Grid RowDefinitions="Auto,*" Margin="4">
        <Grid Grid.Row="0" ColumnDefinitions="*,*">
            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,0,4">
                    <Button Content="Karma verdient" />
                    <Button Content="Karma ausgegeben" />
                    <Button Content="Aufwendungen bearbeiten" />
                </StackPanel>
                <Grid ColumnDefinitions="80,50,*" Margin="0,0,0,2">
                    <TextBlock Grid.Column="0" Classes="gridHeader" Text="Datum" />
                    <TextBlock Grid.Column="1" Classes="gridHeader" Text="Menge" />
                    <TextBlock Grid.Column="2" Classes="gridHeader" Text="Grund" />
                </Grid>
                <ListBox Name="KarmaExpensesListBox" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,0,4">
                    <Button Content="Nuyen verdient" />
                    <Button Content="Nuyen ausgegeben" />
                    <Button Content="Aufwendungen bearbeiten" />
                </StackPanel>
                <Grid ColumnDefinitions="80,60,*" Margin="0,0,0,2">
                    <TextBlock Grid.Column="0" Classes="gridHeader" Text="Datum" />
                    <TextBlock Grid.Column="1" Classes="gridHeader" Text="Menge" />
                    <TextBlock Grid.Column="2" Classes="gridHeader" Text="Grund" />
                </Grid>
                <ListBox Name="NuyenExpensesListBox" />
            </StackPanel>
        </Grid>

        <!-- Real ScottPlot.Avalonia charts (the actual replacement for the WinForms
             System.Windows.Forms.DataVisualization area charts, per the Linux port plan's
             Phase 2 chart decision) - populated from code-behind since ScottPlot's Plot API
             isn't XAML-bindable. -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,8,0,0">
            <Border Grid.Column="0" BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,4,0"
                    Height="180">
                <avalonia:AvaPlot Name="KarmaChart" />
            </Border>
            <Border Grid.Column="1" BorderBrush="#D0D0D0" BorderThickness="1" Margin="4,0,0,0"
                    Height="180">
                <avalonia:AvaPlot Name="NuyenChart" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
