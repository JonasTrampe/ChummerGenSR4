<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Chummer.NewUI.Controls"
             xmlns:vm="clr-namespace:Chummer.NewUI.ViewModels"
             x:Class="Chummer.NewUI.Controls.CharacterSections.ImprovementsTab"
             x:DataType="vm:ImprovementsSectionViewModel">
    <controls:TreeDetailPane TreeWidth="220" ContentMargin="8">
        <controls:TreeDetailPane.HeaderContent>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,0,4">
                    <Button Content="Verbesserung hinzufügen" />
                    <Button Content="Verbesserung bearbeiten" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,0,4">
                    <Button Content="Löschen" />
                    <Button Content="Gruppe hinzufügen" />
                </StackPanel>
            </StackPanel>
        </controls:TreeDetailPane.HeaderContent>
        <controls:TreeDetailPane.TreeContent>
            <ListBox ItemsSource="{Binding Improvements}" SelectedItem="{Binding SelectedImprovement}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ImprovementRowViewModel">
                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </controls:TreeDetailPane.TreeContent>
        <controls:TreeDetailPane.DetailContent>
            <StackPanel Margin="8,0,0,0" Spacing="6">
                <controls:InfoRow Label="Typ:" Value="{Binding SelectedImprovement.Type}" />
                <controls:InfoRow Label="Ziel:" Value="{Binding SelectedImprovement.Target}" />
                <controls:InfoRow Label="Wert:" Value="{Binding SelectedImprovement.Value}" />
                <controls:InfoRow Label="Quelle:" Value="{Binding SelectedImprovement.Source}" />
                <CheckBox Content="aktiv" IsChecked="{Binding SelectedImprovement.IsEnabled}" IsEnabled="False" />
            </StackPanel>
        </controls:TreeDetailPane.DetailContent>
    </controls:TreeDetailPane>
</UserControl>
