<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Chummer.NewUI.Controls"
             xmlns:vm="clr-namespace:Chummer.NewUI.ViewModels"
             x:Class="Chummer.NewUI.Controls.CharacterSections.SkillsSectionTab"
             x:DataType="vm:SkillsSectionViewModel">
    <!-- Real layout is a horizontal split (splitSkills in the designer file): top
	     row = groups | actions side by side, bottom row = Wissensfertigkeiten as
	     its own full-width strip - NOT nested to the right of Aktionsfertigkeiten
	     the way the previous pass had it. -->
    <Grid RowDefinitions="*,Auto" ColumnDefinitions="180,4,*" Margin="4">
        <DockPanel Grid.Row="0" Grid.Column="0" Margin="2 8 2 4">
            <TextBlock DockPanel.Dock="Top" Text="Fertigkeitsgruppen" FontWeight="Bold"
                       Margin="0,0,0, 18" />
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding SkillGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:GroupRowViewModel">
                            <controls:GroupRow GroupName="{Binding GroupName}" Rating="{Binding Rating}"
                                                IsCreateMode="{Binding IsCreateMode}"
                                                RatingValue="{Binding RatingValue, Mode=TwoWay}"
                                                RaiseClicked="OnRaiseGroupClick" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <GridSplitter Grid.Row="0" Grid.Column="1" Background="#E4E4E4" />

        <DockPanel Grid.Row="0" Grid.Column="2" Margin="2 8 2 4">
            <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto" Margin="8,0,0,6">
                <Button Grid.Column="0" Content="Exotische Fertigkeit hinzufügen" Click="OnAddExoticSkillClick" />
                <TextBlock Grid.Column="2" Classes="gridHeader" Text="Aktionsfertigkeiten"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox Grid.Column="3" Width="220" HorizontalAlignment="Right"
                          ItemsSource="{Binding SkillFilters}"
                          SelectedItem="{Binding SelectedSkillFilter, Mode=TwoWay}" />
            </Grid>

            <ScrollViewer>
                <StackPanel>

                <ItemsControl Margin="8,0,0,0" ItemsSource="{Binding ActiveSkills}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SkillRowViewModel">
                            <controls:SkillRow SkillName="{Binding SkillName}" Attribute="{Binding Attribute}"
                                                Rating="{Binding Rating}" Pool="{Binding Pool}"
                                                PoolTooltip="{Binding PoolTooltip}"
                                                Specialization="{Binding Specialization, Mode=TwoWay}"
                                                IsGroupLocked="{Binding IsGroupLocked}"
                                                IsCreateMode="{Binding IsCreateMode}"
                                                RatingValue="{Binding RatingValue, Mode=TwoWay}"
                                                RaiseClicked="OnRaiseSkillClick"
                                                SpecializationCommitted="OnSpecializationCommitted" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- Wissensfertigkeiten: its own full-width strip below groups+actions,
	     not nested inside the actions column. -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" BorderBrush="#E4E4E4"
                BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="8,6,0,0">
            <StackPanel Margin="2 8 2 4">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Wissensfertigkeiten" FontWeight="Bold" />
                    <Button Grid.Column="1" Content="Fertigkeit" Click="OnAddKnowledgeSkillClick" />
                </Grid>
                <!-- Name | Rating | [+] | Pool | Spezialisierung dropdown | [+] | Kategorie dropdown | Löschen -->
                <ItemsControl Margin="0,4,0,0" ItemsSource="{Binding KnowledgeSkills}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:KnowledgeSkillRowViewModel">
                            <Grid ColumnDefinitions="160,50,40,160,130,Auto" Margin="0,2,0,2" ColumnSpacing="6">
                                <TextBox Grid.Column="0" Text="{Binding SkillName}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding Rating}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding Pool}" ToolTip.Tip="{Binding PoolTooltip}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <TextBox Grid.Column="3" Text="{Binding Specialization}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="4" ItemsSource="{Binding Categories}"
                                          SelectedItem="{Binding Category}" />
                                <Button Grid.Column="5" Content="Löschen" Click="OnDeleteKnowledgeSkillClick"
                                        Tag="{Binding SkillId}" IsEnabled="{Binding AllowDelete}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
