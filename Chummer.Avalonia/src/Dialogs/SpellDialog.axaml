<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Chummer.NewUI.Dialogs.SpellDialog"
        Width="560" Height="480" CanResize="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft Sans Serif, Tahoma, Segoe UI, sans-serif"
        FontSize="11"
        Background="White"
        Title="Zauberspruch auswählen">
	<Grid RowDefinitions="*,Auto" Margin="12">
		<Grid Grid.Row="0" ColumnDefinitions="240,4,*">
			<TreeView Grid.Column="0">
				<TreeViewItem Header="Geomatisches Ritual" />
				<TreeViewItem Header="Heilzauber" />
				<TreeViewItem Header="Illusionszauber" />
				<TreeViewItem Header="Kampfzauber" />
				<TreeViewItem Header="Manipulationszauber" />
				<TreeViewItem Header="Wahrnehmungszauber" IsExpanded="True">
					<TreeViewItem Header="Adlerauge" />
					<TreeViewItem Header="Astrale Hellsicht" />
					<TreeViewItem Header="Astrales Fenster" />
					<TreeViewItem Header="Blutschau" />
					<TreeViewItem Header="Borgen" />
					<TreeViewItem Header="Diagnose" />
					<TreeViewItem Header="Feinde aufspüren" />
					<TreeViewItem Header="Feinde aufspüren, Erweitertes" />
					<TreeViewItem Header="Geheimer Handschlag" />
					<TreeViewItem Header="Geistessonde" />
					<TreeViewItem Header="Gerät Analysieren" />
					<TreeViewItem Header="Hellhören" />
					<TreeViewItem Header="Hellsicht" />
					<TreeViewItem Header="Huckepack" />
					<TreeViewItem Header="Individuum aufspüren" />
					<TreeViewItem Header="Infrarot" />
					<TreeViewItem Header="Kampfsinn" />
					<TreeViewItem Header="Katalog" />
					<TreeViewItem Header="Leben aufspüren" />
					<TreeViewItem Header="Leben aufspüren, Erweitertes" />
					<TreeViewItem Header="[Lebensform] aufspüren" />
					<TreeViewItem Header="Luftblase Aufspüren" />
					<TreeViewItem Header="Luftblase Aufspüren, Erweitert" />
					<TreeViewItem Header="Gedankenmuster" IsSelected="True" />
					<TreeViewItem Header="Gedankenscan" />
				</TreeViewItem>
			</TreeView>

			<GridSplitter Grid.Column="1" Background="#E4E4E4" />

			<StackPanel Grid.Column="2" Margin="8,0,0,0" Spacing="8">
				<Grid ColumnDefinitions="Auto,*">
					<TextBlock Text="Suche:" VerticalAlignment="Center" Margin="0,0,8,0" />
					<TextBox Grid.Column="1" />
				</Grid>

				<TextBlock Text="Eigenschaften: Aktiv, psychisch, Blickrichtungsgebun" TextWrapping="Wrap" />
				<TextBlock Text="Typ: M" />
				<TextBlock Text="Reichweite: B" />
				<TextBlock Text="Schaden:" />
				<TextBlock Text="Dauer: A" />
				<TextBlock Text="Entzugsformel: (K÷2)" />
				<CheckBox Content="Eingeschränkter Zauberspruch" />
				<TextBlock Text="Quelle: SM 203" Margin="0,20,0,0" />
			</StackPanel>
		</Grid>

		<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6" Margin="0,12,0,0">
			<Button Content="Weitere" Width="80" />
			<Button Content="Abbruch" Width="80" Click="OnCancel" />
			<Button Content="OK" Width="80" Click="OnOk" />
		</StackPanel>
	</Grid>
</Window>
