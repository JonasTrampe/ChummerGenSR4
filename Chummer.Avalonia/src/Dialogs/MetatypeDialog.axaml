<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Chummer.NewUI.ViewModels"
        x:Class="Chummer.NewUI.Dialogs.MetatypeDialog"
        x:DataType="vm:MetatypeDialogViewModel"
        Width="520" Height="420" CanResize="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft Sans Serif, Tahoma, Segoe UI, sans-serif"
        FontSize="11"
        Background="White"
        Title="Wählen Sie einen Metatyp">
	<Grid RowDefinitions="*,Auto" Margin="12">
		<Grid Grid.Row="0" ColumnDefinitions="180,*" ColumnSpacing="12">
			<StackPanel Grid.Column="0" Spacing="6">
				<ComboBox ItemsSource="{Binding Categories}"
				          Width="170"
				          SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" />
				<ListBox ItemsSource="{Binding Metatypes}"
				         Height="300"
				         SelectedItem="{Binding SelectedMetatype, Mode=TwoWay}">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding Name}" />
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</StackPanel>

			<Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
				<TextBlock Grid.Row="0" Text="{Binding SelectedMetatype.Name}" FontWeight="Bold" FontSize="14" />

				<Grid Grid.Row="1" ColumnDefinitions="60,*,70,*" ColumnSpacing="8">
					<TextBlock Grid.Column="0" Text="GP" FontWeight="Bold" />
					<TextBlock Grid.Column="1" Text="{Binding SelectedMetatype.Bp}" />
				</Grid>

				<Grid Grid.Row="2" ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="12">
					<TextBlock Grid.Row="0" Grid.Column="0" Text="KON" FontWeight="Bold" />
					<TextBlock Grid.Row="0" Grid.Column="1" Text="GES" FontWeight="Bold" />
					<TextBlock Grid.Row="0" Grid.Column="2" Text="REA" FontWeight="Bold" />
					<TextBlock Grid.Row="0" Grid.Column="3" Text="STR" FontWeight="Bold" />
					<TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding SelectedMetatype.BodRange}" />
					<TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedMetatype.AgiRange}" />
					<TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding SelectedMetatype.ReaRange}" />
					<TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SelectedMetatype.StrRange}" />

					<TextBlock Grid.Row="2" Grid.Column="0" Text="CHA" FontWeight="Bold" Margin="0,6,0,0" />
					<TextBlock Grid.Row="2" Grid.Column="1" Text="INT" FontWeight="Bold" Margin="0,6,0,0" />
					<TextBlock Grid.Row="2" Grid.Column="2" Text="LOG" FontWeight="Bold" Margin="0,6,0,0" />
					<TextBlock Grid.Row="2" Grid.Column="3" Text="WIL" FontWeight="Bold" Margin="0,6,0,0" />
					<TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding SelectedMetatype.ChaRange}" />
					<TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedMetatype.IntRange}" />
					<TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding SelectedMetatype.LogRange}" />
					<TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding SelectedMetatype.WilRange}" />

					<TextBlock Grid.Row="4" Grid.Column="0" Text="INI" FontWeight="Bold" Margin="0,6,0,0" />
					<TextBlock Grid.Row="4" Grid.Column="1" Text="EDG" FontWeight="Bold" Margin="0,6,0,0" />
					<TextBlock Grid.Row="4" Grid.Column="2" Text="MAG" FontWeight="Bold" Margin="0,6,0,0" />
					<TextBlock Grid.Row="4" Grid.Column="3" Text="RES" FontWeight="Bold" Margin="0,6,0,0" />
					<TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding SelectedMetatype.IniRange}" />
					<TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedMetatype.EdgRange}" />
					<TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding SelectedMetatype.MagRange}" />
					<TextBlock Grid.Row="5" Grid.Column="3" Text="{Binding SelectedMetatype.ResRange}" />
				</Grid>

				<StackPanel Grid.Row="3" Spacing="4">
					<TextBlock Text="Metavariante:" />
					<ComboBox Width="220"
					          HorizontalAlignment="Left"
					          ItemsSource="{Binding Metavariants}"
					          SelectedItem="{Binding SelectedMetavariant, Mode=TwoWay}" />
				</StackPanel>

				<Grid Grid.Row="4" ColumnDefinitions="90,*" ColumnSpacing="8">
					<TextBlock Grid.Column="0" Text="Essenz" FontWeight="Bold" />
					<TextBlock Grid.Column="1" Text="{Binding SelectedMetatype.EssRange}" />
				</Grid>
			</Grid>
		</Grid>

		<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6" Margin="0,12,0,0">
			<Button Content="Abbruch" Width="80" Click="OnCancel" />
			<Button Content="OK" Width="80" Click="OnOk" />
		</StackPanel>
	</Grid>
</Window>
