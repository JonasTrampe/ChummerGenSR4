<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Chummer.NewUI.ViewModels"
        xmlns:controls="clr-namespace:Chummer.NewUI.Controls"
        x:Class="Chummer.NewUI.Dialogs.CyberwareDialog"
        x:DataType="vm:CyberwareDialogViewModel"
        Width="620" Height="520" WindowStartupLocation="CenterOwner" Title="Cyberware/Bioware auswählen">
    <Grid RowDefinitions="Auto,*,Auto" Margin="12">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,150,Auto,150,Auto,*" Margin="0,0,0,8">
            <TextBlock Grid.Column="0" Text="Kategorie:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" />
            <TextBlock Grid.Column="2" Text="Grad:" VerticalAlignment="Center" Margin="16,0,6,0" />
            <ComboBox Grid.Column="3" ItemsSource="{Binding Grades}"
                      SelectedItem="{Binding SelectedGrade, Mode=TwoWay}" />
            <TextBlock Grid.Column="4" Text="Suche:" VerticalAlignment="Center" Margin="16,0,6,0" />
            <TextBox Grid.Column="5" Text="{Binding SearchText, Mode=TwoWay}" />
        </Grid>
        <Grid Grid.Row="1" ColumnDefinitions="*,200">
            <ListBox ItemsSource="{Binding CyberwareOptions}" SelectedItem="{Binding SelectedCyberware, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CyberwareOptionViewModel">
                        <StackPanel Margin="4,2">
                            <TextBlock Text="{Binding Name}" Foreground="#1E5FA8" />
                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#666666" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="6">
                <TextBlock Text="Kategorie:" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedCyberware.Category, TargetNullValue=–}" />
                <TextBlock Text="Stufe:" FontWeight="Bold" IsVisible="{Binding SelectedCyberware.HasRating}" />
                <controls:IntegerSpinner Value="{Binding SelectedCyberware.RatingValue, Mode=TwoWay}"
                                          Minimum="1" Maximum="{Binding SelectedCyberware.MaxRating}"
                                          IsVisible="{Binding SelectedCyberware.HasRating}" Width="90" HorizontalAlignment="Left" />
                <TextBlock Text="Essenz:" FontWeight="Bold" />
                <TextBlock Text="{Binding FinalEssence}" />
                <TextBlock Text="Kapazität:" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedCyberware.Capacity, TargetNullValue=–}" />
                <TextBlock Text="Verfügbarkeit:" FontWeight="Bold" />
                <TextBlock Text="{Binding FinalAvailability}" />
                <TextBlock Text="Kosten:" FontWeight="Bold" />
                <TextBlock Text="{Binding FinalCost}" />
                <TextBlock Text="Quelle:" FontWeight="Bold" Margin="0,12,0,0" />
                <TextBlock Text="{Binding SelectedCyberware.SourcePage, TargetNullValue=–}" />
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
            <Button Grid.Column="1" Content="Abbruch" Width="80" Margin="0,0,6,0" Click="OnCancel" />
            <Button Grid.Column="2" Content="Hinzufügen" Width="80" Click="OnOk" />
        </Grid>
    </Grid>
</Window>
