<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Chummer.NewUI.Dialogs.SheetPreviewDialog"
        Width="700" Height="640"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft Sans Serif, Tahoma, Segoe UI, sans-serif"
        FontSize="11"
        Background="White"
        Title="Charakterbogen Vorschau">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
            <Button Content="Drucken" />
            <Button Content="Als PDF exportieren" />
            <Button Content="Schließen" Click="OnClose" />
        </StackPanel>
        <Border BorderBrush="#D0D0D0" BorderThickness="1">
            <TextBox Name="SheetHtmlPanel" IsReadOnly="True" AcceptsReturn="True"
                     TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto"
                     FontFamily="monospace" />
        </Border>
    </DockPanel>
</Window>
