<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Chummer.NewUI.Dialogs.AddExoticSkillDialog"
        Width="420" Height="260" CanResize="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft Sans Serif, Tahoma, Segoe UI, sans-serif"
        FontSize="11" Background="White" Title="Exotische Fertigkeit hinzufügen">
    <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" ColumnDefinitions="110,*">
        <TextBlock Grid.Row="0" Text="Fertigkeit:" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameBox" />
        <TextBlock Grid.Row="1" Text="Sub-Typ:" VerticalAlignment="Center" Margin="0,8,0,0" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="SubTypeBox" Margin="0,8,0,0" />
        <TextBlock Grid.Row="2" Text="Kategorie:" VerticalAlignment="Center" Margin="0,8,0,0" />
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CategoryBox" Margin="0,8,0,0" SelectedIndex="0">
            <ComboBoxItem Content="Combat Active" />
            <ComboBoxItem Content="Magical Active" />
            <ComboBoxItem Content="Physical Active" />
            <ComboBoxItem Content="Resonance Active" />
            <ComboBoxItem Content="Social Active" />
            <ComboBoxItem Content="Technical Active" />
            <ComboBoxItem Content="Vehicle Active" />
        </ComboBox>
        <TextBlock Grid.Row="3" Text="Attribut:" VerticalAlignment="Center" Margin="0,8,0,0" />
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="AttributeBox" Margin="0,8,0,0" SelectedIndex="0">
            <ComboBoxItem Content="BOD" />
            <ComboBoxItem Content="AGI" />
            <ComboBoxItem Content="REA" />
            <ComboBoxItem Content="STR" />
            <ComboBoxItem Content="CHA" />
            <ComboBoxItem Content="INT" />
            <ComboBoxItem Content="LOG" />
            <ComboBoxItem Content="WIL" />
            <ComboBoxItem Content="MAG" />
            <ComboBoxItem Content="RES" />
        </ComboBox>
        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ErrorText" Foreground="#B00020" TextWrapping="Wrap" Margin="0,8,0,0" />
        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
            <Button Content="Abbruch" Width="80" Click="OnCancel" />
            <Button Content="Hinzufügen" Width="80" Click="OnOk" />
        </StackPanel>
    </Grid>
</Window>
