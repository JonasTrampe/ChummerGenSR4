<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Chummer.NewUI.Dialogs.QualityDialog"
        Width="620" Height="520" CanResize="True"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft Sans Serif, Tahoma, Segoe UI, sans-serif"
        FontSize="11"
        Background="White"
        Title="Gabe auswählen">
    <Grid RowDefinitions="Auto,*,Auto" Margin="12">
        <TextBlock Grid.Row="0" Text="Wähle eine noch nicht vorhandene Gabe oder ein Handicap aus den installierten Regeln aus."
                   Margin="0,0,0,8" />

        <Grid Grid.Row="1" ColumnDefinitions="*,190">
            <ListBox x:Name="QualityList" Grid.Column="0" ItemsSource="{Binding QualityOptions, x:CompileBindings=False}"
                     SelectionChanged="OnSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate x:CompileBindings="False">
                        <StackPanel Margin="4,2">
                            <TextBlock Text="{Binding DisplayName}" Foreground="#1E5FA8" />
                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#666666" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="8">
                <TextBlock Text="GP:" FontWeight="Bold" />
                <TextBlock x:Name="CostText" Text="–" />
                <TextBlock Text="Quelle:" FontWeight="Bold" />
                <TextBlock x:Name="SourceText" Text="–" />
                <TextBlock Text="Kategorie:" FontWeight="Bold" />
                <TextBlock x:Name="CategoryText" Text="–" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
            <Button Grid.Column="1" Content="Abbruch" Width="80" Margin="0,0,6,0" Click="OnCancel" />
            <Button Grid.Column="2" Content="Hinzufügen" Width="80" Click="OnOk" />
        </Grid>
    </Grid>
</Window>
