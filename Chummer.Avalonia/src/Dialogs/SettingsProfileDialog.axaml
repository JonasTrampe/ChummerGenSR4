<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogs="clr-namespace:Chummer.NewUI.Dialogs"
        x:Class="Chummer.NewUI.Dialogs.SettingsProfileDialog"
        Width="400" Height="200" CanResize="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft Sans Serif, Tahoma, Segoe UI, sans-serif"
        FontSize="11"
        Background="White"
        Title="Einstellung wählen">
	<StackPanel Margin="12" Spacing="10">
		<TextBlock Foreground="#2E6B2E" TextWrapping="Wrap"
		           Text="Wählen Sie ein Einstellungsprofil. Jedes Profil regelt die Generierungsart, Anzahl der Generierungspunkte, die maximale Verfügbarkeit und jegliche Haus-Regeln die für bei der Erschaffung eines Charakters benutzt werden." />

		<Grid ColumnDefinitions="Auto,*">
			<TextBlock Text="Konfigurationsdatei:" VerticalAlignment="Center" Margin="0,0,8,0" />
			<ComboBox Grid.Column="1" HorizontalAlignment="Stretch" SelectedIndex="0" x:DataType="dialogs:SettingsProfileDialog"
			          ItemsSource="{Binding SettingsProfiles, x:CompileBindings=False}"
			          DisplayMemberBinding="{Binding Name, x:CompileBindings=False}" />
		</Grid>

		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6" Margin="0,20,0,0">
			<Button Content="Abbruch" Width="80" Click="OnCancel" />
			<Button Content="OK" Width="80" Click="OnOk" />
		</StackPanel>
	</StackPanel>
</Window>
