                                                <TextBlock Grid.Column="1" Text="-4" />
                                                <TextBlock Grid.Column="2" Text="Fertigkeit Flugzeuge 1 -&gt; 2" />
                                            </Grid>
                                        </ListBoxItem>
                                        <ListBoxItem>
                                            <Grid ColumnDefinitions="80,50,*">
                                                <TextBlock Grid.Column="0" Text="20.10.2016" />
                                                <TextBlock Grid.Column="1" Text="17" />
                                                <TextBlock Grid.Column="2" Text="Missionsbelohnung" />
                                            </Grid>
                                        </ListBoxItem>
                                    </ListBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,0,4">
                                        <Button Content="Nuyen verdient" />
                                        <Button Content="Nuyen ausgegeben" />
                                        <Button Content="Aufwendungen bearbeiten" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="80,60,*" Margin="0,0,0,2">
                                        <TextBlock Grid.Column="0" Classes="gridHeader" Text="Datum" />
                                        <TextBlock Grid.Column="1" Classes="gridHeader" Text="Menge" />
                                        <TextBlock Grid.Column="2" Classes="gridHeader" Text="Grund" />
                                    </Grid>
                                    <ListBox>
                                        <ListBoxItem>
                                            <Grid ColumnDefinitions="80,60,*">
                                                <TextBlock Grid.Column="0" Text="13.07.2026" />
                                                <TextBlock Grid.Column="1" Text="-5¥" Foreground="Red" />
                                                <TextBlock Grid.Column="2"
                                                           Text="Erworbene Ausrüstung Ersatzladestreifen" />
                                            </Grid>
                                        </ListBoxItem>
                                        <ListBoxItem>
                                            <Grid ColumnDefinitions="80,60,*">
                                                <TextBlock Grid.Column="0" Text="20.10.2016" />
                                                <TextBlock Grid.Column="1" Text="-120¥" Foreground="Red" />
                                                <TextBlock Grid.Column="2"
                                                           Text="Erworbene Ausrüstung Thermal-Fussgelenksch..." />
                                            </Grid>
                                        </ListBoxItem>
                                        <ListBoxItem>
                                            <Grid ColumnDefinitions="80,60,*">
                                                <TextBlock Grid.Column="0" Text="20.10.2016" />
                                                <TextBlock Grid.Column="1" Text="-1.000¥" Foreground="Red" />
                                                <TextBlock Grid.Column="2"
                                                           Text="Fahrzeugmodifikation gekauft Chämäleonbezug" />
                                            </Grid>
                                        </ListBoxItem>
                                    </ListBox>
                                </StackPanel>
                            </Grid>

                            <!-- Real ScottPlot.Avalonia charts (the actual replacement for the WinForms
                                 System.Windows.Forms.DataVisualization area charts, per the Linux port plan's
                                 Phase 2 chart decision) - populated from code-behind in MainWindow.axaml.cs
                                 since ScottPlot's Plot API isn't XAML-bindable. -->
                            <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,8,0,0">
                                <Border Grid.Column="0" BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,4,0"
                                        Height="180">
                                    <sp:AvaPlot Name="KarmaChart" />
                                </Border>
                                <Border Grid.Column="1" BorderBrush="#D0D0D0" BorderThickness="1" Margin="4,0,0,0"
                                        Height="180">
                                    <sp:AvaPlot Name="NuyenChart" />
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- ================= Kalender ================= -->
