<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:Chummer.AvaloniaSpike.Controls"
        xmlns:sp="using:ScottPlot.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="745"
        x:Class="Chummer.AvaloniaSpike.MainWindow"
        Width="1280" Height="745"
        FontFamily="Microsoft Sans Serif, Tahoma, Segoe UI, sans-serif"
        FontSize="11"
        Background="White"
        Title="Chummer - [Karriere Modus (Default Settings)]">

    <!-- v2: matches a fuller set of real reference screenshots. Two things the first pass
	     got wrong, fixed here:
	     1) The real app is themed by Windows' modern common-controls visual style (white
	        backgrounds, thin light borders, blue underline on the selected tab) - not the
	        chunky classic-Windows look the first pass pushed toward.
	     2) The right sidebar is itself a 2-tab control ("Weitere Informationen" /
	        "Zustandsmonitor"), not a single flat panel - it swaps content but stays visible
	        across every main tab (splitMain in the real designer file). -->

    <DockPanel LastChildFill="True">

        <Menu DockPanel.Dock="Top" Background="White">
            <MenuItem Header="_Datei">
                <MenuItem Header="_Neu" />
                <MenuItem Header="Ö_ffnen..." />
                <MenuItem Header="_Speichern" />
                <Separator />
                <MenuItem Header="_Drucken" />
                <Separator />
                <MenuItem Header="_Schließen" />
            </MenuItem>
            <MenuItem Header="_Zubehör" />
            <MenuItem Header="_Spezial" />
            <MenuItem Header="_Fenster" />
            <MenuItem Header="_Hilfe" />
        </Menu>

        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E4E4E4" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="2">
                <Button Name="NewCharacterButton" Classes="toolbarButton"
                        ToolTip.Tip="Neu (öffnet den Charaktererschaffungs-Assistenten)"
                        AutomationProperties.Name="Neu" Click="OnNewCharacterClick">
                    <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/page.png" />
                </Button>
                <Button Classes="toolbarButton" ToolTip.Tip="Öffnen"
                        AutomationProperties.Name="Öffnen" Click="OnOpenCharacterClick">
                    <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/folder_page.png" />
                </Button>
                <Button Classes="toolbarButton" ToolTip.Tip="Speichern unter"
                        AutomationProperties.Name="Speichern unter" Click="OnSaveCharacterClick">
                    <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/disk.png" />
                </Button>
                <Button Classes="toolbarButton" ToolTip.Tip="Drucken"
                        AutomationProperties.Name="Drucken" Click="OnPrintClick">
                    <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/printer.png" />
                </Button>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E4E4E4" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Margin="6,3" Spacing="24">
                <TextBlock Name="KarmaStatus" Text="Karma: 1" />
                <TextBlock Text="Essenz: 0,80" />
                <TextBlock Name="NuyenStatus" Text="Nuyen: 1.435¥" />
            </StackPanel>
        </Border>

        <!-- Character-tab strip: one tab per open character window, sitting between the
		     toolbar and the per-character content tabs (Allgemein/Fertigkeiten/...) - this is
		     the actual MDI-replacement mechanism the real app already uses (confirmed from
		     reference screenshots), not something we need to invent for the Linux port. -->
        <TabControl DockPanel.Dock="Top" Classes="characterTabs"
                    ItemsSource="{Binding OpenCharacters}"
                    SelectedItem="{Binding SelectedOpenCharacter, Mode=TwoWay}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                        <Button Content="×" Click="OnCloseCharacterTabClick"
                                ToolTip.Tip="Charakter schließen" Padding="3,0" MinWidth="0" />
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E4E4E4" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,4,270">

                <TabControl Grid.Column="0">
                    <!-- ================= Allgemein ================= -->
                    <TabItem Header="Allgemein">
                        <controls:TreeDetailPane TreeWidth="280" ContentMargin="2 8 2 4">
                            <controls:TreeDetailPane.HeaderContent>
                                <StackPanel Margin="2 0 2 0" Orientation="Horizontal" Spacing="2">
                                    <Button Content="Gabe hinzufügen" Click="OnAddQualityClick" />
                                    <Button Content="Gabe austauschen" />
                                    <Button Content="Löschen" />
                                </StackPanel>
                            </controls:TreeDetailPane.HeaderContent>
                            <controls:TreeDetailPane.TreeContent>
                                <TreeView Name="QualitiesTree">
                                    <TreeViewItem Header="Gabe auswählen">
                                        <TreeViewItem Header="Mehr als metamenschlich" />
                                        <TreeViewItem Header="Restlichtverstärkung" />
                                    </TreeViewItem>
                                    <TreeViewItem Header="Handicap auswählen" IsExpanded="True">
                                        <TreeViewItem Header="Medienjunkie (leicht)" />
                                        <TreeViewItem Header="SIN-Mensch (Standard) (Yagi Shigeru)" />
                                        <TreeViewItem Header="Tierschreck" />
                                        <TreeViewItem Header="Verschuldet (20.000¥)" />
                                    </TreeViewItem>
                                </TreeView>
                            </controls:TreeDetailPane.TreeContent>
                            <controls:TreeDetailPane.DetailContent>
                                <ScrollViewer Margin="2 8 2 4">
                                <StackPanel Margin="4,0,4,0" Spacing="10">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,60,Auto,60">
                                        <TextBlock Grid.Column="0" Text="Spitzname:" VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBox Name="AliasTextBox" Grid.Column="1" Width="260" HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="2" Text="Metatyp:" VerticalAlignment="Center"
                                                   Margin="20,0,6,0" />
                                        <TextBlock Name="MetatypeText" Grid.Column="3" Text="Ork" FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="Nuyen:" VerticalAlignment="Center"
                                                   Margin="20,0,6,0" />
                                        <TextBox Name="NuyenTextBox" Grid.Column="5" Text="0" />
                                        <TextBlock Name="NuyenEquivalentText" Grid.Column="6" Text="= 0¥" VerticalAlignment="Center"
                                                   Margin="6,0,0,0" />
                                    </Grid>

                                    <StackPanel>
                                        <Grid ColumnDefinitions="150,40,26,60,90,60" Margin="0,0,0,2">
                                            <TextBlock Grid.Column="0" Classes="gridHeader" Text="Attribute" />
                                            <TextBlock Grid.Column="1" Classes="gridHeader" Text="Basis" />
                                            <TextBlock Grid.Column="3" Classes="gridHeader" Text="(Verst.)" />
                                            <TextBlock Grid.Column="4" Classes="gridHeader" Text="Metatyp Begrenzu." />
                                            <TextBlock Grid.Column="5" Classes="gridHeader" Text="Quelle" />
                                        </Grid>
                                        <StackPanel>
                                            <controls:AttributeRow Name="BODAttribute" AttributeName="Konstitution (KON)" Base="4"
                                                                   Range="4 / 9 (13)" Source="SR4 89" />
                                            <controls:AttributeRow Name="AGIAttribute" AttributeName="Geschicklichkeit (GES)" Base="5"
                                                                   Augmented="(7)" Range="1 / 6 (9)" />
                                            <controls:AttributeRow Name="REAAttribute" AttributeName="Reaktion (REA)" Base="5"
                                                                   Augmented="(7)" Range="1 / 6 (9)" />
                                            <controls:AttributeRow Name="STRAttribute" AttributeName="Stärke (STR)" Base="3"
                                                                   Augmented="(4)" Range="3 / 8 (12)" />
                                            <controls:AttributeRow Name="CHAAttribute" AttributeName="Charisma (CHA)" Base="2"
                                                                   Range="1 / 5 (7)" />
                                            <controls:AttributeRow Name="INTAttribute" AttributeName="Intuition (INT)" Base="5"
                                                                   Range="1 / 6 (9)" />
                                            <controls:AttributeRow Name="LOGAttribute" AttributeName="Logik (LOG)" Base="5"
                                                                   Range="1 / 5 (7)" />
                                            <controls:AttributeRow Name="WILAttribute" AttributeName="Willenskraft (WIL)" Base="2"
                                                                   Range="1 / 6 (9)" />
                                            <controls:AttributeRow Name="EDGAttribute" AttributeName="Edge (EDG)" Base="3"
                                                                   Range="1 / 6 (6)" ShowRemove="True" />
                                            <controls:AttributeRow Name="MAGAttribute" AttributeName="Magie (MAG)" Base="6"
                                                                   Range="1 / 6 (6)" />
                                            <controls:AttributeRow Name="RESAttribute" AttributeName="Resonanz (RES)" Base="1"
                                                                   Range="1 / 6 (6)" IsEnabled="False" />
                                        </StackPanel>

                                        <!-- Magician-Adept hybrid characters split their Magic rating between the
									     two disciplines - only relevant for that combination, but shown here
									     unconditionally since this is a static look-and-feel demo. -->
                                        <Border Classes="groupBox" Padding="10" HorizontalAlignment="Left"
                                                Margin="0,4,0,0">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Magieadept MAG-Aufteilung" FontWeight="Bold" />
                                                <Grid ColumnDefinitions="90,90">
                                                    <TextBlock Grid.Column="0" Text="Magier" FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1" Text="Adept" FontWeight="SemiBold" />
                                                </Grid>
                                                <Grid ColumnDefinitions="90,90">
                                                    <TextBox Grid.Column="0" Text="3" Width="60"
                                                             HorizontalAlignment="Left" />
                                                    <TextBlock Grid.Column="1" Text="3" VerticalAlignment="Center" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Connections:" FontWeight="Bold" Margin="0,0,0,4" />
                                        <Button Content="Connection hinzufügen" HorizontalAlignment="Left"
                                                Margin="0,0,0,6" />
                                        <Border BorderBrush="#E4E4E4" BorderThickness="0,0,0,1" Padding="0,0,0,4"
                                                Margin="0,0,0,4">
                                            <Grid ColumnDefinitions="140,Auto,50,Auto,50,Auto,Auto" ColumnSpacing="6">
                                                <TextBlock Grid.Column="0" Text="Schieber: Stef"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="Connection:"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="3" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Text="Loyalität:" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="4" Text="2" VerticalAlignment="Center" />
                                                <Border Classes="iconButton">
                                                    <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/link.png" />
                                                </Border>
                                                <Button Grid.Column="6" Content="Lösch" />
                                            </Grid>
                                        </Border>
                                        <Border BorderBrush="#E4E4E4" BorderThickness="0,0,0,1" Padding="0,0,0,4">
                                            <Grid ColumnDefinitions="140,Auto,50,Auto,50,Auto,Auto" ColumnSpacing="6">
                                                <TextBlock Grid.Column="0" Text="StreetDoc: Tim"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="Connection:"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="2" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Text="Loyalität:" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="4" Text="2" VerticalAlignment="Center" />
                                                <Border Classes="iconButton">
                                                    <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/link.png" />
                                                </Border>
                                                <Button Grid.Column="6" Content="Lösch" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Feinde" FontWeight="Bold" Margin="0,0,0,4" />
                                        <Button Content="Feind hinzufügen" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </StackPanel>
                                </ScrollViewer>
                            </controls:TreeDetailPane.DetailContent>
                        </controls:TreeDetailPane>
                    </TabItem>

                    <!-- ================= Fertigkeiten ================= -->
                    <TabItem Header="Fertigkeiten">
                        <!-- Real layout is a horizontal split (splitSkills in the designer file): top
					     row = groups | actions side by side, bottom row = Wissensfertigkeiten as
					     its own full-width strip - NOT nested to the right of Aktionsfertigkeiten
					     the way the previous pass had it. -->
                        <Grid RowDefinitions="*,Auto" ColumnDefinitions="180,4,*" Margin="4">
                            <DockPanel Grid.Row="0" Grid.Column="0" Margin="2 8 2 4">
                                <TextBlock DockPanel.Dock="Top" Text="Fertigkeitsgruppen" FontWeight="Bold"
                                           Margin="0,0,0, 18" />
                                <ScrollViewer>
                                    <StackPanel Name="SkillGroupsPanel">
                                        <controls:GroupRow GroupName="Athletik" Rating="2" />
                                        <controls:GroupRow GroupName="Beschwören" Rating="0" />
                                        <controls:GroupRow GroupName="Biotech" Rating="2" />
                                        <controls:GroupRow GroupName="Cracken" Rating="0" />
                                        <controls:GroupRow GroupName="Einfluss" Rating="0" />
                                        <controls:GroupRow GroupName="Elektronik" Rating="0" />
                                        <controls:GroupRow GroupName="Feuerwaffen" Rating="0" />
                                        <controls:GroupRow GroupName="Heimlichkeit" Rating="2" />
                                        <controls:GroupRow GroupName="Hexerei" Rating="0" />
                                        <controls:GroupRow GroupName="Mechanik" Rating="2" />
                                        <controls:GroupRow GroupName="Nahkampf" Rating="1" />
                                        <controls:GroupRow GroupName="Natur" Rating="1" />
                                        <controls:GroupRow GroupName="Tasken" Rating="0" />
                                        <controls:GroupRow GroupName="Tierhaltung" Rating="0" />
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>

                            <GridSplitter Grid.Row="0" Grid.Column="1" Background="#E4E4E4" />

                            <DockPanel Grid.Row="0" Grid.Column="2" Margin="2 8 2 4">
                                <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto" Margin="8,0,0,6">
                                    <Button Grid.Column="0" Content="Exotische Fertigkeit hinzufügen" />
                                    <TextBlock Grid.Column="2" Classes="gridHeader" Text="Aktionsfertigkeiten"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox Grid.Column="3" Width="220" HorizontalAlignment="Right" SelectedIndex="0">
                                        <ComboBoxItem Content="Zeige alle aktiven Fertigkeiten" />
                                    </ComboBox>
                                </Grid>

                                <ScrollViewer>
                                    <StackPanel>

                                    <WrapPanel Name="ActiveSkillsPanel" Margin="8,0,0,0">

                                        <controls:SkillRow SkillName="Abrichten" Attribute="INT" Rating="0" Pool="4" />
                                        <controls:SkillRow SkillName="Akrobatik" Attribute="GES" Rating="2" Pool="9" />
                                        <controls:SkillRow SkillName="Antimagie" Attribute="MAG" Rating="0" Pool="0" IsUnavailable="True" />
                                        <controls:SkillRow SkillName="Arcana" Attribute="LOG" Rating="0" Pool="0" IsUnavailable="True" />
                                        <controls:SkillRow SkillName="Askennen" Attribute="INT" Rating="0" Pool="0" />
                                        <controls:SkillRow SkillName="Astralkampf" Attribute="WIL" Rating="0" Pool="0" IsUnavailable="True" />
                                        <controls:SkillRow SkillName="Ausweichen" Attribute="REA" Rating="4" Pool="11 (13)" Specialization="Kugeln" />
                                        <controls:SkillRow SkillName="Beschatten" Attribute="INT" Rating="2" Pool="7" />
                                        <controls:SkillRow SkillName="Binden" Attribute="MAG" Rating="0" Pool="0" IsUnavailable="True" />
                                        <controls:SkillRow SkillName="Bodenfahrzeuge" Attribute="REA" Rating="3" Pool="10" />
                                        <controls:SkillRow SkillName="Chemie" Attribute="LOG" Rating="0" Pool="0" />
                                        <controls:SkillRow SkillName="Computer" Attribute="LOG" Rating="4" Pool="9" />
                                        <controls:SkillRow SkillName="Datensuche" Attribute="LOG" Rating="5" Pool="10" />
                                        <controls:SkillRow SkillName="Dekompilieren" Attribute="RES" Rating="0" Pool="0" IsUnavailable="True" />
                                        <controls:SkillRow SkillName="Einschüchtern" Attribute="CHA" Rating="0" Pool="1" />
                                        <controls:SkillRow SkillName="Elektronische Kriegsführung" Attribute="LOG" Rating="2" Pool="7" />
                                        <controls:SkillRow SkillName="Entfesseln" Attribute="GES" Rating="1" Pool="8" />
                                        <controls:SkillRow SkillName="Fälschung" Attribute="LOG" Rating="0" Pool="0" />
                                        <controls:SkillRow SkillName="Gerätschaft" Attribute="LOG" Rating="2" Pool="7" />
                                        <controls:SkillRow SkillName="Kunstfertigkeit" Attribute="CHA" Rating="0" Pool="1" />
                                        <controls:SkillRow SkillName="Medizin" Attribute="LOG" Rating="2" Pool="7" IsGroupLocked="True" />
                                        <controls:SkillRow SkillName="Navigation" Attribute="INT" Rating="0" Pool="5" />
                                        <controls:SkillRow SkillName="Pistolen" Attribute="GES" Rating="0" Pool="6" />
                                        <controls:SkillRow SkillName="Registrieren" Attribute="MAG" Rating="0" Pool="0" IsUnavailable="True" />
                                        <controls:SkillRow SkillName="Reiten" Attribute="REA" Rating="0" Pool="5" />
                                        <controls:SkillRow SkillName="Schwere Waffen" Attribute="GES" Rating="0" Pool="6" />
                                        <controls:SkillRow SkillName="Sprengstoffe" Attribute="LOG" Rating="0" Pool="0" />
                                        <controls:SkillRow SkillName="Verhandlung" Attribute="CHA" Rating="0" Pool="1" />
                                        <controls:SkillRow SkillName="Wahrnehmung" Attribute="INT" Rating="2" Pool="7" />
                                        <controls:SkillRow SkillName="Wahrnehmung (Sehen)" Attribute="INT" Rating="2" Pool="7" IsMetaskill="True" />
                                        <controls:SkillRow SkillName="Wahrnehmung (Hören)" Attribute="INT" Rating="2" Pool="7" IsMetaskill="True" />
                                        <controls:SkillRow SkillName="Werfen" Attribute="GES" Rating="0" Pool="6" />
                                        <controls:SkillRow SkillName="Zauberei" Attribute="MAG" Rating="0" Pool="0" IsUnavailable="True" />
                                    </WrapPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>

                            <!-- Wissensfertigkeiten: its own full-width strip below groups+actions,
						     not nested inside the actions column. -->
                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" BorderBrush="#E4E4E4"
                                    BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="8,6,0,0">
                                <StackPanel Margin="2 8 2 4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="Wissensfertigkeiten" FontWeight="Bold" />
                                        <Button Grid.Column="1" Content="Fertigkeit" />
                                    </Grid>
                                    <!-- Name | Rating | [+] | Pool | Spezialisierung dropdown | [+] | Kategorie dropdown | Löschen -->
                                    <Grid ColumnDefinitions="140,26,20,26,140,20,110,Auto"
                                          RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="4" Margin="0,4,0,0">
                                        <ComboBox Grid.Row="0" Grid.Column="0" Width="130" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Bars und Clubs" />
                                        </ComboBox>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="1" VerticalAlignment="Center" />
                                        <Button Grid.Row="0" Grid.Column="2" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                        </Button>
                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="6" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="0" Grid.Column="4" Width="130" HorizontalAlignment="Left" />
                                        <Button Grid.Row="0" Grid.Column="5" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                        </Button>
                                        <ComboBox Grid.Row="0" Grid.Column="6" Width="100" HorizontalAlignment="Left"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Straßenwissen" />
                                        </ComboBox>
                                        <Button Grid.Row="0" Grid.Column="7" Content="Löschen" />

                                        <ComboBox Grid.Row="1" Grid.Column="0" Width="130" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Data Havens" />
                                        </ComboBox>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="2" VerticalAlignment="Center" />
                                        <Button Grid.Row="1" Grid.Column="2" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                        </Button>
                                        <TextBlock Grid.Row="1" Grid.Column="3" Text="7" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="1" Grid.Column="4" Width="130" HorizontalAlignment="Left" />
                                        <Button Grid.Row="1" Grid.Column="5" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                        </Button>
                                        <ComboBox Grid.Row="1" Grid.Column="6" Width="100" HorizontalAlignment="Left"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Berufswissen" />
                                        </ComboBox>
                                        <Button Grid.Row="1" Grid.Column="7" Content="Löschen" />

                                        <ComboBox Grid.Row="2" Grid.Column="0" Width="130" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Deutsch" />
                                        </ComboBox>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="2" VerticalAlignment="Center" />
                                        <Button Grid.Row="2" Grid.Column="2" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                        </Button>
                                        <TextBlock Grid.Row="2" Grid.Column="3" Text="7" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="2" Grid.Column="4" Width="130" HorizontalAlignment="Left" />
                                        <Button Grid.Row="2" Grid.Column="5" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                        </Button>
                                        <ComboBox Grid.Row="2" Grid.Column="6" Width="100" HorizontalAlignment="Left"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Sprache" />
                                        </ComboBox>
                                        <Button Grid.Row="2" Grid.Column="7" Content="Löschen" />

                                        <ComboBox Grid.Row="3" Grid.Column="0" Width="130" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Englisch" />
                                        </ComboBox>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="2" VerticalAlignment="Center" />
                                        <Button Grid.Row="3" Grid.Column="2" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                        </Button>
                                        <TextBlock Grid.Row="3" Grid.Column="3" Text="7" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="3" Grid.Column="4" Width="130" HorizontalAlignment="Left" />
                                        <Button Grid.Row="3" Grid.Column="5" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                        </Button>
                                        <ComboBox Grid.Row="3" Grid.Column="6" Width="100" HorizontalAlignment="Left"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Sprache" />
                                        </ComboBox>
                                        <Button Grid.Row="3" Grid.Column="7" Content="Löschen" />

                                        <ComboBox Grid.Row="4" Grid.Column="0" Width="130" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Feuerwaffen" />
                                        </ComboBox>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="1" VerticalAlignment="Center" />
                                        <Button Grid.Row="4" Grid.Column="2" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                        </Button>
                                        <TextBlock Grid.Row="4" Grid.Column="3" Text="6" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="4" Grid.Column="4" Width="130" HorizontalAlignment="Left" />
                                        <Button Grid.Row="4" Grid.Column="5" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                        </Button>
                                        <ComboBox Grid.Row="4" Grid.Column="6" Width="100" HorizontalAlignment="Left"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Berufswissen" />
                                        </ComboBox>
                                        <Button Grid.Row="4" Grid.Column="7" Content="Löschen" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ================= Kampfkünste ================= -->
                    <TabItem Header="Kampfkünste">
                        <controls:TreeDetailPane TreeWidth="220" ContentMargin="2 8 2 4">
                            <controls:TreeDetailPane.HeaderContent>
                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,0,4">
                                    <Button Content="Kampfkunst hinzufügen" />
                                    <Button Content="Manöver hinzufügen" />
                                    <Button Content="Löschen" />
                                </StackPanel>
                            </controls:TreeDetailPane.HeaderContent>
                            <controls:TreeDetailPane.TreeContent>
                                <ListBox>
                                    <ListBoxItem Content="Ausgewählte Kampfkunst" FontStyle="Italic" Foreground="#888888" />
                                    <ListBoxItem Content="Ausgewählte Manöver" FontStyle="Italic" Foreground="#888888" />
                                </ListBox>
                            </controls:TreeDetailPane.TreeContent>
                            <controls:TreeDetailPane.DetailContent>
                                <StackPanel Margin="12,0,0,0" Spacing="6">
                                    <Grid ColumnDefinitions="Auto,Auto">
                                        <TextBlock Text="Stufe:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <Button Grid.Column="1" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                        </Button>
                                    </Grid>
                                    <TextBlock Text="Quelle:" />
                                </StackPanel>
                            </controls:TreeDetailPane.DetailContent>
                        </controls:TreeDetailPane>
                    </TabItem>

                    <!-- ================= Adeptenkräfte (conditional tab - Adept characters only) ================= -->
                    <TabItem Header="Adeptenkräfte">
                        <DockPanel Margin="2 8 2 4">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                                <Button Content="Kraft" />
                                <TextBlock Text="Kraftpunkte: 6 (0,00 verbleibend)" FontWeight="Bold"
                                           VerticalAlignment="Center" />

                            </StackPanel>
                            <StackPanel>
                                <controls:AdeptPowerRow PowerName="Gesteigerte Reflexe 3" PowerLevel="1"
                                                        PricePerLevel="x 3,00 / Stufe" TotalCost="= 3,00"
                                                        IsWayOfTheAdept="true" />
                                <controls:AdeptPowerRow PowerName="Schnellziehen" PowerLevel="1"
                                                        PricePerLevel="x 0,50 / Stufe" TotalCost="= 0,50"
                                                        IsWayOfTheAdept="true" IsNudEnabled="False" />

                                <controls:AdeptPowerRow PowerName="Verbesserte Fertigkeit (Kampf) (Gewehre)" PowerLevel="3"
                                                        PricePerLevel="x 0,50 / Stufe" TotalCost="= 1,50"
                                                        IsWayOfTheAdept="true" IsNudEnabled="True" />

                                <controls:AdeptPowerRow PowerName="Verbesserte Wahrnehmung" PowerLevel="4"
                                                        PricePerLevel="x 0,25 / Stufe" TotalCost="= 1,00"
                                                        IsWayOfTheAdept="true" IsNudEnabled="True" />

                            </StackPanel>
                        </DockPanel>
                    </TabItem>

                    <!-- ================= Sprüche und Geister (conditional tab - Magician/Adept characters) ================= -->
                    <TabItem Header="Sprüche und Geister">
                        <DockPanel Margin="8">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="2" Margin="0,0,0,4">
                                <Button Content="Zauber hinzufügen" Click="OnAddSpellClick" />
                                <Button Content="Löschen" />
                            </StackPanel>
                            <Grid ColumnDefinitions="220,4,*" RowDefinitions="*,Auto">
                                <DockPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock DockPanel.Dock="Top" Text="Ausgewählte Zauber" FontWeight="Bold" Margin="0,0,0,4" />
                                    <TreeView>
                                    <TreeViewItem Header="Kampfzauber auswählen" IsExpanded="True">
                                        <TreeViewItem Header="Bö" />
                                    </TreeViewItem>
                                    <TreeViewItem Header="Wahrnehmungszauber auswählen" />
                                    <TreeViewItem Header="Heilzauber auswählen" />
                                    <TreeViewItem Header="Illusionszauber auswählen" />
                                    <TreeViewItem Header="Manipulationszauber auswählen" />
                                    <TreeViewItem Header="Ausgewählte Geomantie Rituale" />
                                    </TreeView>
                                </DockPanel>

                                <GridSplitter Grid.Row="0" Grid.Column="1" Background="#E4E4E4" />

                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,0" Spacing="6">
                                <Grid ColumnDefinitions="*,*">
                                    <TextBlock Grid.Column="0" Text="Eigenschaften: Indirekt, Elementar" />
                                    <TextBlock Grid.Column="1" Text="Kategorie: Kampfzauber" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*">
                                    <TextBlock Grid.Column="0" Text="Typ: P" />
                                    <TextBlock Grid.Column="1" Text="Reichweite: BF" />
                                    <TextBlock Grid.Column="2" Text="Schaden: K" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*">
                                    <TextBlock Grid.Column="0" Text="Dauer: S" />
                                    <TextBlock Grid.Column="1" Text="Entzugsformel: (K+2)+3" />
                                </Grid>
                                <controls:InfoRow Label="Quelle:" Value="SM 194" />
                                <controls:InfoRow Label="Würfelpool:" Value="9" />

                                <Grid ColumnDefinitions="Auto,150">
                                    <TextBlock Text="Tradition:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox Grid.Column="1" SelectedIndex="0">
                                        <ComboBoxItem Content="Chaosmagie" />
                                    </ComboBox>
                                </Grid>
                                <controls:InfoRow Label="Entzug widerstehen: WIL + LOG" Value="2" />
                            </StackPanel>

                            <!-- Geister section spans the full tab width, below the spell tree/detail split -->
                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" BorderBrush="#E4E4E4"
                                    BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,6,0,0">
                                <StackPanel>
                                    <TextBlock Text="Geister" FontWeight="Bold" Margin="0,0,0,4" />
                                    <Button Content="Geist" HorizontalAlignment="Left" Margin="0,0,0,6" />
                                    <Grid ColumnDefinitions="140,180,60,50,60,50,20,20,Auto" ColumnSpacing="6">
                                        <ComboBox Grid.Column="0" SelectedIndex="0">
                                            <ComboBoxItem Content="Erdgeist" />
                                        </ComboBox>
                                        <TextBox Grid.Column="1" Text="Tim" />
                                        <TextBlock Grid.Column="2" Text="Macht:" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="3" Text="3" />
                                        <TextBlock Grid.Column="4" Text="Dienste:" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="5" Text="0" />
                                        <CheckBox Grid.Column="6" Content="gebunden" IsChecked="True" />
                                        <Border Grid.Column="7" Classes="iconButton">
                                            <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/link.png" />
                                        </Border>
                                        <Button Grid.Column="8" Content="Löschen" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            </Grid>
                        </DockPanel>
                    </TabItem>

                    <!-- ================= Initiation (conditional tab - Awakened characters only) ================= -->
                    <TabItem Header="Initiation">
                        <Grid ColumnDefinitions="220,4,*" Margin="8">
                            <DockPanel Grid.Column="0">
                                <Button DockPanel.Dock="Top" Content="Metamagie Hinzufügen" Margin="0,0,0,4" />
                                <ListBox>
                                    <ListBoxItem Content="Zusätzlicher Kraftpunkt" />
                                </ListBox>
                            </DockPanel>

                            <GridSplitter Grid.Column="1" Background="#E4E4E4" />

                            <StackPanel Grid.Column="2" Margin="8,0,0,0" Spacing="8">
                                <Grid ColumnDefinitions="Auto,40,26,Auto,Auto">
                                    <TextBlock Grid.Column="0" Text="Initiatengrad:" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="1" VerticalAlignment="Center" />
                                    <Button Grid.Column="2" Classes="iconButton">
                                        <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" />
                                    </Button>
                                    <CheckBox Grid.Column="3" Content="Gruppeninitiation (-20%)" Margin="16,0,0,0" />
                                </Grid>
                                <CheckBox Content="Initiationsprüfung (-20%)" />

                                <Grid ColumnDefinitions="*,*">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Quelle:" FontWeight="Bold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Geschichte:" FontWeight="Bold" />
                                        <Border Classes="groupBox" Height="70">
                                            <TextBlock Margin="4" Text="Grad 1 (Prüfung)" />
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <CheckBox Content="beigetretene Gruppe:" />
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Text="Gruppe:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBox Grid.Column="1" />
                                </Grid>
                                <TextBlock Text="Notizen:" FontWeight="Bold" />
                                <Border Classes="groupBox" Height="120" />
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- ================= Cyberware und Bioware ================= -->
                    <TabItem Header="Cyberware und Bioware">
                        <controls:TreeDetailPane TreeWidth="330" ContentMargin="4">
                            <controls:TreeDetailPane.HeaderContent>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Spacing="2">
                                    <Button Content="Cyberware hinzufügen" />
                                    <Button Content="Bioware hinzufügen" />
                                    <Button Content="Löschen" />
                                </StackPanel>
                            </controls:TreeDetailPane.HeaderContent>
                            <controls:TreeDetailPane.TreeContent>
                                <TreeView Name="CyberwareTree">
                                    <TreeViewItem Header="Cyberware auswählen">
                                        <TreeViewItem Header="Cyberaugen-Basissystem (Stufe 4)" IsExpanded="True">
                                            <TreeViewItem Header="Augen-Rekorder" />
                                            <TreeViewItem Header="Bildverbindung" />
                                            <TreeViewItem Header="Sichtverbesserung (Stufe 3)" />
                                            <TreeViewItem Header="Smartlink, Smartgunverbindung" />
                                        </TreeViewItem>
                                        <TreeViewItem Header="Cyberohren (Stufe 3)" IsExpanded="True">
                                            <TreeViewItem Header="Ohr-Rekorder" />
                                            <TreeViewItem Header="Audioverbindung" />
                                            <TreeViewItem Header="Selektiver Geräuschfilter (Stufe 4)" />
                                        </TreeViewItem>
                                        <TreeViewItem Header="Datenbuchse" />
                                        <TreeViewItem Header="Reflexbooster (Stufe 2)" />
                                    </TreeViewItem>
                                    <TreeViewItem Header="Bioware auswählen">
                                        <TreeViewItem Header="Muskelstraffung (Stufe 2)" />
                                    </TreeViewItem>
                                </TreeView>
                            </controls:TreeDetailPane.TreeContent>
                            <controls:TreeDetailPane.DetailContent>
                                <StackPanel Margin="8,0,0,0" Spacing="6">
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Width="80" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Kategorie:" Width="80" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Verfügbarkeit:" Width="80" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Quelle:" Width="80" />
                                </Grid>
                                <Separator Margin="0,4" />
                                <Grid ColumnDefinitions="*,*,*,*">
                                    <TextBlock Grid.Column="0" Text="Prozessor:" />
                                    <TextBlock Grid.Column="1" Text="Signal:" />
                                    <TextBlock Grid.Column="2" Text="System:" />
                                    <TextBlock Grid.Column="3" Text="Firewall:" />
                                </Grid>
                                <Separator Margin="0,4" />
                                <TextBlock Text="Verbrauchte Essenz" FontWeight="Bold" />
                                <Grid ColumnDefinitions="Auto,60" RowDefinitions="Auto,Auto,Auto" RowSpacing="2">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Cyberware:" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="4,90" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Bioware:" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="0,30" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Verlorene Essenz:" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="0,00" />
                                </Grid>
                                </StackPanel>
                            </controls:TreeDetailPane.DetailContent>
                        </controls:TreeDetailPane>
                    </TabItem>

                    <!-- ================= Straßenausrüstung (nested sub-tabs) ================= -->
                    <TabItem Header="Straßenausrüstung">
                        <TabControl Margin="4">
                            <TabItem Header="Lebensstil">
                                <Grid ColumnDefinitions="200,4,*" Margin="4">
                                    <DockPanel Grid.Column="0">
                                        <Button DockPanel.Dock="Top" Content="Lebensstil hinzufügen" Margin="0,0,0,4" />
                                        <ListBox>
                                            <ListBoxItem Content="Mittelschicht" />
                                        </ListBox>
                                    </DockPanel>
                                    <GridSplitter Grid.Column="1" Background="#E4E4E4" />
                                    <StackPanel Grid.Column="2" Margin="8,0,0,0" Spacing="4">
                                        <TextBlock Text="Kosten/Monat:" />
                                        <TextBlock
                                            Text="Komfort / Unterhaltung / Grundversorgung / Wohngegend / Sicherheit"
                                            Foreground="#666666" FontStyle="Italic" />
                                    </StackPanel>
                                </Grid>
                            </TabItem>
                            <TabItem Header="Panzerung">
                                <controls:TreeDetailPane TreeWidth="220" ContentMargin="4">
                                    <controls:TreeDetailPane.HeaderContent>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Spacing="2">
                                            <Button Content="Panzerung hinzufügen" />
                                            <Button Content="Löschen" />
                                            <Button Content="Panzerungsset hinzufügen" />
                                        </StackPanel>
                                    </controls:TreeDetailPane.HeaderContent>
                                    <controls:TreeDetailPane.TreeContent>
                                        <TreeView Name="ArmorTree">
                                            <TreeViewItem Header="Panzerung auswählen" />
                                            <TreeViewItem Header="Actioneer Geschäftsanzug" IsExpanded="True">
                                                <TreeViewItem Header="Chemische Isolierung (Stufe 6)" />
                                            </TreeViewItem>
                                            <TreeViewItem Header="Formangepasste Ganzkörperpanzerung" IsExpanded="True">
                                                <TreeViewItem Header="Wärmedämpfung (Stufe 4)" />
                                                <TreeViewItem Header="Vitalmonitor" />
                                            </TreeViewItem>
                                        </TreeView>
                                    </controls:TreeDetailPane.TreeContent>
                                    <controls:TreeDetailPane.DetailContent>
                                        <StackPanel Margin="8,0,0,0" Spacing="6">
                                        <Grid ColumnDefinitions="Auto,60,Auto,60,Auto,60" RowSpacing="4">
                                            <TextBlock Grid.Column="0" Text="Ballistisch:" />
                                            <TextBlock Grid.Column="1" Text="0" />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,60">
                                            <TextBlock Grid.Column="0" Text="Stoß:" />
                                            <TextBlock Grid.Column="1" Text="0" />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,60,Auto,80,Auto,60">
                                            <TextBlock Grid.Column="0" Text="Stufe:" />
                                            <TextBlock Grid.Column="1" Text="4" />
                                            <TextBlock Grid.Column="2" Text="Verfügbarkeit:" />
                                            <TextBlock Grid.Column="3" Text="10V" />
                                            <TextBlock Grid.Column="4" Text="Kosten:" />
                                            <TextBlock Grid.Column="5" Text="2.000¥" />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,60">
                                            <TextBlock Grid.Column="0" Text="Kapazität:" />
                                            <TextBlock Grid.Column="1" Text="[0]" />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0" Text="Quelle:" Width="60" />
                                            <TextBlock Grid.Column="1" Text="SR4 372" />
                                        </Grid>
                                        <CheckBox Content="Teil der Standardrüstung" />
                                        <CheckBox Content="angelegt" IsChecked="True" />
                                        </StackPanel>
                                    </controls:TreeDetailPane.DetailContent>
                                </controls:TreeDetailPane>
                            </TabItem>

                            <TabItem Header="Waffen">
                                <controls:TreeDetailPane TreeWidth="300" ContentMargin="4">
                                    <controls:TreeDetailPane.HeaderContent>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Spacing="2">
                                            <Button Content="Waffe hinzufügen" />
                                            <Button Content="Löschen" />
                                            <Button Content="Ort hinzufügen" />
                                        </StackPanel>
                                    </controls:TreeDetailPane.HeaderContent>
                                    <controls:TreeDetailPane.TreeContent>
                                        <TreeView Name="WeaponsTree">
                                            <TreeViewItem Header="Ausgewählte Waffen" />
                                            <TreeViewItem Header="Waffenlos" />
                                            <TreeViewItem Header="HK MP-5 TX" IsExpanded="True">
                                                <TreeViewItem Header="Schallunterdrücker" />
                                                <TreeViewItem Header="Ausklappbare Schulterstütze" />
                                                <TreeViewItem Header="Gasventil-2" />
                                                <TreeViewItem Header="Lasermarkierer" />
                                                <TreeViewItem Header="Smartgunsystem" />
                                                <TreeViewItem Header="Elektronisches Feuern" />
                                                <TreeViewItem Header="Ausgebauter Abzug" />
                                                <TreeViewItem Header="Skinlink" />
                                            </TreeViewItem>
                                            <TreeViewItem Header="ArmTech MGL-12">
                                                <TreeViewItem Header="Airburst-Verbindung" />
                                                <TreeViewItem Header="Elektronisches Feuern" />
                                                <TreeViewItem Header="Smartgunsystem" />
                                                <TreeViewItem Header="Skinlink" />
                                                <TreeViewItem Header="Ausgebauter Abzug" />
                                                <TreeViewItem Header="Zusätzlicher Ladestreifen" />
                                            </TreeViewItem>
                                            <TreeViewItem Header="Minigranate: Betäubung" />
                                            <TreeViewItem Header="Minigranate: Instant-Fangnetz" />
                                            <TreeViewItem Header="Minigranate: Spreng" />
                                            <TreeViewItem Header="Minigranate: IR-Rauch" />
                                            <TreeViewItem Header="Minigranate: Rauch" />
                                        </TreeView>
                                    </controls:TreeDetailPane.TreeContent>
                                    <controls:TreeDetailPane.DetailContent>
                                        <ScrollViewer>
                                            <StackPanel Margin="8,0,0,0" Spacing="6">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Text="Name:" Width="90" />
                                                <TextBlock Grid.Column="1" Text="HK MP-5 TX" FontWeight="SemiBold" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Text="Kategorie:" Width="90" />
                                                <TextBlock Grid.Column="1" Text="Maschinenpistolen" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,*,*">
                                                <TextBlock Grid.Column="0" Text="Schaden: 5K" />
                                                <TextBlock Grid.Column="1" Text="Rückstoßkompensation: 4" />
                                                <TextBlock Grid.Column="2" Text="PB: -" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,*,*">
                                                <TextBlock Grid.Column="0" Text="Reichweite: 0" />
                                                <TextBlock Grid.Column="1" Text="Modus: HM/SM/AM" />
                                                <TextBlock Grid.Column="2" Text="Muni: 20(s)" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,*,*">
                                                <TextBlock Grid.Column="0" Text="Verfügbarkeit: 4E" />
                                                <TextBlock Grid.Column="1" Text="Kosten: 2.500¥" />
                                                <TextBlock Grid.Column="2" Text="Verbergen: +2" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                <TextBlock Grid.Column="0" Text="Mod Slots: 6 (2 verbleibend)" />
                                                <CheckBox Grid.Column="2" Content="Teil der Grundwaffe" />
                                                <CheckBox Grid.Column="3" Content="Installiert" Margin="12,0,0,0" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*,26">
                                                <TextBlock Text="Quelle:" Width="90" />
                                                <TextBlock Grid.Column="1" Text="SR4 363" />
                                                <Border Grid.Column="2" Classes="iconButton">
                                                    <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/page.png" />
                                                </Border>
                                            </Grid>

                                            <TextBlock Text="Reichweite" FontWeight="Bold" Margin="0,4,0,0" />
                                            <Grid ColumnDefinitions="*,*,*,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="kurz" />
                                                    <TextBlock Text="0-10" Foreground="#666666" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="mittel" />
                                                    <TextBlock Text="11-40" Foreground="#666666" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="lang" />
                                                    <TextBlock Text="41-85" Foreground="#666666" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="3">
                                                    <TextBlock Text="extrem" />
                                                    <TextBlock Text="86-150" Foreground="#666666" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,6,0,0">
                                                <TextBlock Grid.Column="0" Text="Verbleibende Munition:"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="20" VerticalAlignment="Center" />
                                                <Button Grid.Column="2" Content="Schießen!" />
                                                <Button Grid.Column="3" Content="Nachladen" Margin="6,0,0,0" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Text="Derzeit ausgewählte Munition:"
                                                           VerticalAlignment="Center" />
                                                <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                          SelectedIndex="0">
                                                    <ComboBoxItem Content="Slot 1 Munition: Standardmunition" />
                                                </ComboBox>
                                            </Grid>
                                            <controls:InfoRow Label="Würfelpool:" Value="13" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </controls:TreeDetailPane.DetailContent>
                                </controls:TreeDetailPane>
                            </TabItem>

                            <TabItem Header="Ausrüstung">
                                <controls:TreeDetailPane TreeWidth="300" ContentMargin="4">
                                    <controls:TreeDetailPane.HeaderContent>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Spacing="2">
                                            <Button Content="Ausrüstung hinzufügen" />
                                            <Button Content="Löschen" />
                                            <Button Content="Ort hinzufügen" />
                                            <CheckBox Content="Zeige nur Kommlinks" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </controls:TreeDetailPane.HeaderContent>
                                    <controls:TreeDetailPane.TreeContent>
                                        <!-- Drag-and-drop reordering wired up in code-behind (SetUpGearDragDrop) -
                                             matches the real app's gear/cyberware reordering in frmCareer/frmCreate,
                                             one of the risk areas flagged in the Linux port plan's Avalonia audit. -->
                                        <TreeView Name="AusruestungTree">
                                            <TreeViewItem Header="Ausrüstung wählen." IsExpanded="True">
                                                <TreeViewItem Header="Untersuchungswerkzeug Kiste" />
                                                <TreeViewItem Header="Custom Commlink (&quot;Schicke Armbanduhr&quot;)"
                                                              IsExpanded="True">
                                                    <TreeViewItem Header="Custom Commlink OS" IsExpanded="True">
                                                        <TreeViewItem Header="Custom Platzhalter (Software)"
                                                                      IsExpanded="True">
                                                            <TreeViewItem Header="Analyse (Stufe 6)" />
                                                            <TreeViewItem Header="Angriff (Stufe 6)" />
                                                            <TreeViewItem Header="Aufspüren (Stufe 6)" />
                                                            <TreeViewItem Header="Ausnutzen (Stufe 6)" />
                                                            <TreeViewItem Header="Befehl (Stufe 6)" />
                                                            <TreeViewItem Header="Datenbombe (Stufe 6)" />
                                                            <TreeViewItem Header="Datenübersetzer (Stufe 6)" />
                                                            <TreeViewItem Header="ECCM (Stufe 6)" />
                                                            <TreeViewItem Header="Editieren (Stufe 6)" />
                                                            <TreeViewItem Header="Panzerung (Stufe 6)" />
                                                            <TreeViewItem Header="Säubern (Stufe 6)" />
                                                            <TreeViewItem Header="Scannen (Stufe 6)" />
                                                            <TreeViewItem Header="Schleicher (Stufe 6)" />
                                                            <TreeViewItem Header="Schmöker (Stufe 6)" />
                                                            <TreeViewItem Header="Schnüffler (Stufe 6)" />
                                                            <TreeViewItem Header="Täuschung (Stufe 6)" />
                                                            <TreeViewItem Header="Verschlüsselung (Stufe 6)" />
                                                        </TreeViewItem>
                                                        <TreeViewItem Header="Custom Platzhalter (Miltec)">
                                                            <TreeViewItem Header="Taktische AR-Software (Stufe 4)" />
                                                            <TreeViewItem Header="Waffenwächtersoftware (Stufe 6)" />
                                                            <TreeViewItem Header="Gesichtserkennungssoftware (Stufe 6)" />
                                                            <TreeViewItem Header="Geräuschanalysesoftware (Stufe 6)" />
                                                            <TreeViewItem Header="Gangarterkennungssoftware (Stufe 6)" />
                                                            <TreeViewItem Header="Sichtsuchersoftware (Stufe 6)" />
                                                            <TreeViewItem Header="Luftabwehrassistent (Stufe 3)" />
                                                            <TreeViewItem Header="Medic (Stufe 6)" />
                                                            <TreeViewItem Header="Clearsight (Stufe 4)" />
                                                        </TreeViewItem>
                                                        <TreeViewItem Header="Custom Platzhalter (Agenten)">
                                                            <TreeViewItem Header="Die Drei Musketiere (Stufe 6)" />
                                                            <TreeViewItem Header="Agent (Stufe 6)" />
                                                            <TreeViewItem Header="Agent (Stufe 6)" />
                                                        </TreeViewItem>
