                                                <TextBlock Grid.Column="1" Text="-4" />
                                                <TextBlock Grid.Column="2" Text="Fertigkeit Flugzeuge 0 -&gt; 1" />
                                            </Grid>
                                        </ListBoxItem>
                                        <ListBoxItem>
                                            <Grid ColumnDefinitions="80,50,*">
