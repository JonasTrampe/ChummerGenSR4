<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.AvaloniaSpike.Controls.GroupRow"
             x:Name="root">
	<!-- One Fertigkeitsgruppen row: Name | Rating | [+]. -->
	<Grid ColumnDefinitions="*,20,26" DataContext="{Binding ElementName=root}" MinHeight="22">
		<TextBlock Grid.Column="0" Classes="rowLabel" Text="{Binding GroupName}" />
		<TextBlock Grid.Column="1" Classes="rowLabel" HorizontalAlignment="Right" Text="{Binding Rating}" />
		<Button Grid.Column="2" Classes="iconButton">
			<Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" Width="16" Height="16" />
		</Button>
	</Grid>
</UserControl>
