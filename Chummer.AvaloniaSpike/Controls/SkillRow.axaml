<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Chummer.AvaloniaSpike.Controls.SkillRow"
             x:Name="root">
    <!-- One Aktionsfertigkeiten/Wissensfertigkeiten row: Name | Attribut | Basis | [+] | Pool |
         Spezialisierung | [+]. Every instance shares the exact same column widths, so a stack of
         these lines up in clean columns automatically. The Border's background carries the row's
         category (has-a-pool tint vs group-locked tint); text dimming for unavailable skills is
         layered on top via the existing rowLabel/disabledRow classes. -->
    <Border Classes="skillRow" Classes.hasPool="{Binding HasPool, ElementName=root}"
            Classes.groupLocked="{Binding IsGroupLocked, ElementName=root}">
        <Grid ColumnDefinitions="150,30,20,16,40,160,16" DataContext="{Binding ElementName=root}" MinHeight="24">
            <TextBlock Grid.Column="0" Classes="rowLabel" Classes.disabledRow="{Binding IsUnavailable}"
                       Text="{Binding SkillName}" />
            <TextBlock Grid.Column="1" Classes="rowLabel" HorizontalAlignment="Center"
                       Classes.disabledRow="{Binding IsUnavailable}" Text="{Binding Attribute}" Foreground="#777777" />
            <TextBlock Grid.Column="2" Classes="rowLabel" HorizontalAlignment="Center"
                       Classes.disabledRow="{Binding IsUnavailable}" Text="{Binding Rating}" />
            <Button Grid.Column="3" Classes="iconButton" HorizontalAlignment="Center"
                    IsVisible="{Binding !IsUnavailable}" IsEnabled="{Binding CanEditRating}">
                <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" Width="16" Height="16" />
            </Button>
            <TextBlock Grid.Column="4" Classes="rowLabel" HorizontalAlignment="Center"
                       Classes.disabledRow="{Binding IsUnavailable}" Text="{Binding Pool}" />

            <!-- Specialization slot: metaskill subskills (e.g. individual Wahrnehmung senses) never
                 get one at all. Otherwise it's always this same combo, whether or not a
                 specialization is already chosen - changing it is a special-occasion action (via
                 karma expenditure elsewhere), not something this row edits directly, so it stays
                 disabled here regardless of rating/lock state. -->
            <ComboBox Grid.Column="5" Width="150" HorizontalAlignment="Left"
                      IsVisible="{Binding !IsMetaskill}" IsEnabled="False" SelectedIndex="0">
                <ComboBoxItem Content="{Binding Specialization}" />
            </ComboBox>

            <Button Grid.Column="6" Classes="iconButton" HorizontalAlignment="Center"
                    IsVisible="{Binding !IsMetaskill}" IsEnabled="{Binding CanEditRating}">
                <Image Source="avares://Chummer.AvaloniaSpike/Assets/icons/add.png" Width="16" Height="16" />
            </Button>
        </Grid>
    </Border>
</UserControl>
